{
  "name": "@sibincbaby/lw-redmine",
  "version": "0.1.0",
  "description": "lwr — Redmine CLI for AI agents",
  "author": "Sibin C Baby <sibincbaby219@gmail.com>",
  "homepage": "https://github.com/sibincbaby/lw-redmine#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sibincbaby/lw-redmine.git"
  },
  "bugs": {
    "url": "https://github.com/sibincbaby/lw-redmine/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lwr": "./dist/cli.js"
  },
  "type": "commonjs",
  "files": [
    "dist",
    "SKILL.md",
    "install.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js 2>/dev/null || true",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "setup": "node install.mjs install",
    "setup:update": "node install.mjs update",
    "setup:skill": "node install.mjs update-skill",
    "setup:status": "node install.mjs status",
    "setup:uninstall": "node install.mjs uninstall",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.10.0",
    "boxen": "^7.1.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "keytar": "^7.9.0",
    "ora": "^7.0.1",
    "picocolors": "^1.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "nock": "^13.5.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "redmine",
    "cli",
    "tui",
    "claude-code",
    "mcp"
  ],
  "license": "MIT"
}
